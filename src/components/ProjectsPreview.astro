---
import { projects } from "~/data/site";
const featured = projects.slice(0, 4);
---

<section class="relative bg-navy-abyss text-paper py-24 lg:py-36 paper-grain overflow-hidden">
  <!-- Soft grid wash -->
  <div class="absolute inset-0 chart-grid opacity-[0.05] pointer-events-none" style="--color-rule: rgba(245,241,232,0.4);"></div>

  <div class="relative max-w-[1440px] mx-auto px-6 lg:px-12">
    <!-- Heading -->
    <div class="grid lg:grid-cols-12 gap-8 mb-16 lg:mb-20 items-end">
      <div class="lg:col-span-7">
        <p class="reveal eyebrow eyebrow-on-dark mb-6">Chapter 03 · Projects</p>
        <h2 class="reveal reveal-delay-1 display-lg text-paper">
          Quiet work behind <em class="emphasis-light">loud projects.</em>
        </h2>
      </div>
      <div class="reveal reveal-delay-2 lg:col-span-4 lg:col-start-9">
        <p class="font-body text-[15px] lg:text-base text-paper/70 leading-relaxed text-pretty">
          A short selection of engagements — energy, infrastructure, and steady forwarding partnerships across the Philippines.
        </p>
      </div>
    </div>

    <!-- Project grid -->
    <div class="grid md:grid-cols-2 gap-6 lg:gap-10">
      {featured.map((p, i) => (
        <a
          href={`/projects#${p.slug}`}
          class={`reveal group block ${i % 2 === 1 ? "md:mt-16" : ""}`}
          style={`transition-delay: ${i * 80}ms;`}
        >
          <div class="relative aspect-[4/3] overflow-hidden bg-slate-sea/30 mb-5">
            <img
              src={p.image}
              alt={p.name}
              loading="lazy"
              class="absolute inset-0 w-full h-full object-cover grayscale-[40%] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-1000 ease-out"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-navy-abyss/60 via-transparent to-transparent"></div>
            <span class="absolute top-4 left-4 font-mono text-[10px] tracking-[0.22em] uppercase text-paper/85">
              {String(i + 1).padStart(2, "0")} / {String(featured.length).padStart(2, "0")}
            </span>
            <span class="absolute bottom-4 left-4 font-mono text-[10px] tracking-[0.2em] uppercase px-2.5 py-1 bg-paper/95 text-navy">
              {p.category}
            </span>
          </div>
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="display-md text-paper group-hover:text-brass-glow transition-colors">
                {p.name}
              </h3>
              <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-paper/55 mt-2">
                {p.location} · {p.role}
              </p>
            </div>
            <svg
              class="w-5 h-5 mt-2 text-paper/55 group-hover:text-brass-glow group-hover:translate-x-1 transition-all"
              viewBox="0 0 20 20"
              fill="none"
              aria-hidden="true"
            >
              <path d="M3 10h14M17 10l-5-5M17 10l-5 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="square"/>
            </svg>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-16 lg:mt-20 flex justify-center">
      <a href="/projects" class="btn-ghost">
        <span>View All Projects</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7h10M12 7L8 3M12 7l-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
        </svg>
      </a>
    </div>
  </div>
</section>
