---
import { site, nav } from "~/data/site";
---

<footer class="relative bg-navy-abyss text-paper paper-grain overflow-hidden">
  <!-- Decorative top rule with brass accent -->
  <div class="h-px bg-gradient-to-r from-transparent via-brass/40 to-transparent"></div>

  <!-- Decorative compass rose (background) -->
  <div class="absolute -right-32 -top-32 w-[500px] h-[500px] opacity-[0.04] pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 500 500" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="250" cy="250" r="240" stroke="currentColor" stroke-width="0.5"/>
      <circle cx="250" cy="250" r="200" stroke="currentColor" stroke-width="0.5"/>
      <circle cx="250" cy="250" r="120" stroke="currentColor" stroke-width="0.5"/>
      <circle cx="250" cy="250" r="60" stroke="currentColor" stroke-width="0.5"/>
      <line x1="250" y1="10" x2="250" y2="490" stroke="currentColor" stroke-width="0.5"/>
      <line x1="10" y1="250" x2="490" y2="250" stroke="currentColor" stroke-width="0.5"/>
      <line x1="79" y1="79" x2="421" y2="421" stroke="currentColor" stroke-width="0.5"/>
      <line x1="421" y1="79" x2="79" y2="421" stroke="currentColor" stroke-width="0.5"/>
      <text x="250" y="40" text-anchor="middle" fill="currentColor" font-family="IBM Plex Mono" font-size="14" letter-spacing="2">N</text>
      <text x="470" y="256" text-anchor="middle" fill="currentColor" font-family="IBM Plex Mono" font-size="14" letter-spacing="2">E</text>
      <text x="250" y="478" text-anchor="middle" fill="currentColor" font-family="IBM Plex Mono" font-size="14" letter-spacing="2">S</text>
      <text x="32" y="256" text-anchor="middle" fill="currentColor" font-family="IBM Plex Mono" font-size="14" letter-spacing="2">W</text>
    </svg>
  </div>

  <div class="relative max-w-[1440px] mx-auto px-6 lg:px-12 pt-20 pb-10">
    <!-- Top: Tagline + crest -->
    <div class="grid lg:grid-cols-12 gap-12 pb-16">
      <div class="lg:col-span-7">
        <p class="eyebrow eyebrow-on-dark mb-6">The Lighthouse · Castillejos, Zambales</p>
        <h2 class="display-lg text-paper">
          Where efficiency meets excellence,<br/>
          <em class="emphasis-light">every mile of the way.</em>
        </h2>
      </div>
      <div class="lg:col-span-5 flex lg:justify-end items-start">
        <img src="/img/logo.png" alt="LuminaOmnia Solutions crest" width="180" height="180" class="w-32 lg:w-44 h-auto" />
      </div>
    </div>

    <div class="rule opacity-30"></div>

    <!-- Middle: link grid + contact -->
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 py-14">
      <div class="lg:col-span-4">
        <p class="eyebrow eyebrow-on-dark mb-4">Direct Line</p>
        <a href={`tel:${site.contact.phone.replace(/\s/g, "")}`} class="display-md text-paper hover:text-brass-glow transition-colors block">
          {site.contact.phone}
        </a>
        <a href={`mailto:${site.contact.email}`} class="font-body text-sm text-paper/70 hover:text-paper transition-colors mt-2 block">
          {site.contact.email}
        </a>
        <p class="font-body text-sm text-paper/55 mt-6 leading-relaxed">
          {site.contact.address}
        </p>
      </div>

      <div class="lg:col-span-3">
        <p class="eyebrow eyebrow-on-dark mb-4">Navigate</p>
        <ul class="space-y-2.5">
          {nav.map((item) => (
            <li>
              <a href={item.href} class="group flex items-baseline gap-3 text-paper/80 hover:text-paper transition-colors">
                <span class="font-mono text-[10px] tracking-widest opacity-50 group-hover:opacity-100">{item.chapter}</span>
                <span class="font-body text-[15px]">{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-3">
        <p class="eyebrow eyebrow-on-dark mb-4">Affiliations</p>
        <ul class="space-y-2.5">
          {site.affiliations.map((a) => (
            <li>
              <span class="display-sm text-paper">{a.name}</span>
              <span class="block font-body text-xs text-paper/50">{a.full}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-2">
        <p class="eyebrow eyebrow-on-dark mb-4">Follow</p>
        <ul class="space-y-2.5">
          <li>
            <a href={site.contact.facebook} target="_blank" rel="noopener noreferrer" class="text-paper/80 hover:text-paper transition-colors font-body text-[15px]">Facebook</a>
          </li>
          <li>
            <a href={site.contact.instagram} target="_blank" rel="noopener noreferrer" class="text-paper/80 hover:text-paper transition-colors font-body text-[15px]">Instagram</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="rule opacity-30"></div>

    <!-- Bottom: copyright -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 pt-8">
      <p class="font-mono text-[10px] tracking-[0.18em] uppercase text-paper/50">
        © {new Date().getFullYear()} {site.name} · All rights reserved
      </p>
      <p class="font-mono text-[10px] tracking-[0.18em] uppercase text-paper/50">
        Castillejos · Zambales · Philippines
      </p>
    </div>
  </div>
</footer>
