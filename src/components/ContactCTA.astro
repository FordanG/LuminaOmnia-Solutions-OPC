---
import { site } from "~/data/site";
---

<section class="relative bg-navy text-paper py-24 lg:py-32 overflow-hidden">
  <!-- Faint compass radial -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.06]">
    <div class="absolute top-1/2 right-0 -translate-y-1/2 w-[800px] h-[800px] -mr-96">
      <svg viewBox="0 0 800 800" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
        <circle cx="400" cy="400" r="380" stroke="#E0AD32" stroke-width="0.5"/>
        <circle cx="400" cy="400" r="280" stroke="#E0AD32" stroke-width="0.5"/>
        <circle cx="400" cy="400" r="180" stroke="#E0AD32" stroke-width="0.5"/>
        <circle cx="400" cy="400" r="80" stroke="#E0AD32" stroke-width="0.5"/>
      </svg>
    </div>
  </div>

  <div class="relative max-w-[1440px] mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-end">
      <div class="lg:col-span-7">
        <p class="reveal eyebrow eyebrow-on-dark mb-6">Talk directly with our team</p>
        <h2 class="reveal reveal-delay-1 display-xl text-paper">
          Let’s discuss<br/><em class="text-signal not-italic">your shipment.</em>
        </h2>
      </div>

      <div class="reveal reveal-delay-2 lg:col-span-5 lg:col-start-8">
        <p class="font-body text-base lg:text-lg text-paper/80 leading-relaxed text-pretty mb-8">
          Share the cargo, origin, destination, and target date. We’ll tell you what we need and the next practical step.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/contact" class="btn-brass">
            <span>View Contact Details</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M12 7L8 3M12 7l-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
            </svg>
          </a>
          <a href={`tel:${site.contact.phone.replace(/\s/g, "")}`} class="btn-ghost">
            <span>{site.contact.phone}</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
