---
const proof = [
  ["Compliance first", "Accurate entries and audit-ready records"],
  ["Senior-led", "Direct access to experienced decision-makers"],
  ["Prepared early", "Requirements checked before cargo arrives"],
  ["End-to-end", "Customs, freight, storage, and delivery"],
];
---

<section class="bg-navy-abyss text-paper border-y border-paper/10" aria-label="How LuminaOmnia works">
  <div class="max-w-[1440px] mx-auto grid sm:grid-cols-2 lg:grid-cols-4">
    {proof.map(([title, body], i) => (
      <div class="px-6 lg:px-10 py-7 border-b sm:border-r border-paper/12 last:border-r-0 sm:[&:nth-last-child(-n+2)]:border-b-0 lg:border-b-0">
        <div class="flex gap-4">
          <span class="font-mono text-signal text-xs mt-0.5">{String(i + 1).padStart(2, "0")}</span>
          <div>
            <h2 class="font-display uppercase tracking-wide text-xl text-paper">{title}</h2>
            <p class="font-body text-xs leading-relaxed text-paper/58 mt-1">{body}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
