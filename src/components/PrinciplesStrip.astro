---
import { principles } from "~/data/site";
---

<section class="bg-paper-warm py-24 lg:py-36 paper-grain">
  <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-12 gap-8 mb-16 items-end">
      <div class="lg:col-span-7">
        <p class="reveal eyebrow mb-6">House Principles</p>
        <h2 class="reveal reveal-delay-1 display-lg text-navy">
          The way <em class="emphasis-dark">we work.</em>
        </h2>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-px bg-rule">
      {principles.map((p, i) => (
        <div class="reveal bg-paper-warm p-8 lg:p-10" style={`transition-delay: ${i * 80}ms;`}>
          <span class="number-block block mb-6">
            {p.number}
          </span>
          <h3 class="display-sm text-navy mb-4">
            {p.title}
          </h3>
          <p class="font-body text-[15px] text-slate-sea leading-relaxed text-pretty">
            {p.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
