---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { site } from "~/data/site";
---

<BaseLayout
  title="Contact Our Customs Brokerage Team"
  description="Contact LuminaOmnia Solutions in Castillejos, Zambales by phone or email for customs brokerage, logistics coordination, and trade compliance support."
>
  <section class="relative bg-navy-abyss text-paper pt-32 pb-16 lg:pt-40 lg:pb-28 overflow-hidden">
    <div class="absolute inset-0 route-field opacity-20" aria-hidden="true"></div>
    <div class="relative max-w-[1440px] mx-auto px-6 lg:px-12 grid lg:grid-cols-12 gap-8 items-end">
      <div class="lg:col-span-8">
        <p class="eyebrow eyebrow-on-dark mb-7">Direct contact · Castillejos, Zambales</p>
        <h1 class="display-xl text-paper">Talk to the person<br/><span class="text-signal">accountable for the work.</span></h1>
      </div>
      <p class="lg:col-span-4 text-base lg:text-lg text-paper/70 leading-relaxed">Share your cargo, origin, destination, and target date by phone or email. We’ll tell you the next practical step.</p>
    </div>
  </section>

  <section class="bg-paper py-16 lg:py-24">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-12">
      <div class="grid lg:grid-cols-2 border-t border-rule">
        <a href={`tel:${site.contact.phone.replace(/\s/g, "")}`} class="group py-10 lg:py-14 lg:pr-12 border-b lg:border-r border-rule">
          <p class="eyebrow mb-5">Call</p>
          <p class="display-lg text-navy group-hover:text-lighthouse-deep transition-colors">{site.contact.phone}</p>
          <p class="font-body text-sm text-slate-sea mt-4">Monday–Friday · 8:30 AM–5:30 PM PHT</p>
        </a>
        <a href={`mailto:${site.contact.email}`} class="group py-10 lg:py-14 lg:pl-12 border-b border-rule">
          <p class="eyebrow mb-5">Email</p>
          <p class="font-display uppercase text-[clamp(1.65rem,3vw,3rem)] leading-none text-navy break-all group-hover:text-lighthouse-deep transition-colors">{site.contact.email}</p>
          <p class="font-body text-sm text-slate-sea mt-4">Include cargo type, route, and target date if available.</p>
        </a>
        <div class="py-10 lg:py-14 lg:pr-12 border-b lg:border-r border-rule">
          <p class="eyebrow mb-5">Office</p>
          <address class="display-md text-navy not-italic">{site.contact.address}</address>
          <a href="https://maps.google.com/?q=Nagbayan%2C%20Castillejos%2C%20Zambales%2C%20Philippines" target="_blank" rel="noopener noreferrer" class="inline-block mt-5 ink-link font-mono text-xs uppercase tracking-[.15em]">Open in maps →</a>
        </div>
        <div class="py-10 lg:py-14 lg:pl-12 border-b border-rule">
          <p class="eyebrow mb-5">Follow</p>
          <div class="flex flex-wrap gap-6">
            <a href={site.contact.facebook} target="_blank" rel="noopener noreferrer" class="display-md text-navy hover:text-lighthouse-deep transition-colors">Facebook</a>
            <a href={site.contact.instagram} target="_blank" rel="noopener noreferrer" class="display-md text-navy hover:text-lighthouse-deep transition-colors">Instagram</a>
          </div>
        </div>
      </div>

      <div class="mt-14 bg-paper-warm p-7 lg:p-10 grid lg:grid-cols-12 gap-7 items-center">
        <p class="eyebrow lg:col-span-3">Helpful details to send</p>
        <ul class="lg:col-span-9 grid sm:grid-cols-2 lg:grid-cols-4 gap-4 font-body text-sm text-slate-sea">
          <li>• Cargo description</li><li>• Origin and destination</li><li>• Target arrival date</li><li>• Available documents</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
